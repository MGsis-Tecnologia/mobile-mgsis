# URL base da API REST do ERP (WLanguage/WebDev). Deixe vazio/indefinida para usar o mock.
EXPO_PUBLIC_API_URL=https://api.exemplo.com.br

# "true" (padrão) usa dados simulados localmente em vez do backend real.
# Troque para "false" quando os endpoints reais estiverem prontos.
EXPO_PUBLIC_USE_MOCK=true
